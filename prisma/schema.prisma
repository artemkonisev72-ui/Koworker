generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  emailNormalized         String?                  @unique
  emailVerifiedAt         DateTime?
  passwordHash            String
  name                    String?
  createdAt               DateTime                 @default(now())
  chats                   Chat[]
  sessions                Session[]
  drafts                  TaskDraft[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String?  @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthThrottleBucket {
  id          String   @id @default(cuid())
  action      String
  scopeKeyHash String
  windowStart DateTime
  hitCount    Int      @default(0)
  blockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([action, scopeKeyHash])
  @@index([updatedAt])
}

model Chat {
  id              String     @id @default(cuid())
  userId          String
  title           String     @default("Новый чат")
  modelPreference String     @default("gemini-3.1-flash-lite-preview")
  isPinned        Boolean    @default(false)
  isPublic        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  drafts          TaskDraft[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum DraftStatus {
  DRAFT
  SCHEMA_GENERATED
  AWAITING_REVIEW
  NEEDS_REVISION
  SCHEMA_APPROVED
  SOLVING
  SOLVED
  CANCELED
  FAILED
}

model Message {
  id            String      @id @default(cuid())
  chatId        String
  draftId       String?
  role          MessageRole
  content       String      @db.Text
  generatedCode String?     @db.Text
  executionLogs String?     @db.Text
  graphData     Json?
  exactAnswers  Json?
  schemaData    Json?
  schemaDescription String? @db.Text
  schemaVersion String?     @default("1.0")
  usedModels    Json?
  imageData     String?     @db.Text
  createdAt     DateTime    @default(now())
  chat          Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  draft         TaskDraft?  @relation(fields: [draftId], references: [id], onDelete: SetNull)
  attachments   MessageAttachment[]

  @@index([chatId])
  @@index([draftId])
}

enum MessageAttachmentKind {
  PDF
  DOCX
}

model MessageAttachment {
  id                String                @id @default(cuid())
  messageId         String
  kind              MessageAttachmentKind
  fileName          String
  mimeType          String
  sizeBytes         Int
  base64Data        String                @db.Text
  extractedText     String?               @db.Text
  renderedImageData String?               @db.Text
  pageCount         Int?
  usedPageCount     Int?
  createdAt         DateTime              @default(now())
  message           Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model TaskDraft {
  id               String              @id @default(cuid())
  chatId            String
  userId            String
  mode              String              @default("standard")
  status            DraftStatus         @default(DRAFT)
  schemaVersion     String              @default("1.0")
  originalPrompt    String              @db.Text
  originalImageData String?             @db.Text
  currentUnderstanding Json?
  approvedUnderstanding Json?
  currentIntent     Json?
  approvedIntent    Json?
  currentSchema     Json?
  approvedSchema    Json?
  currentSchemeDescription  String?    @db.Text
  approvedSchemeDescription String?    @db.Text
  solverModel       Json?
  revisionCount     Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  chat              Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions         TaskDraftRevision[]
  messages          Message[]

  @@index([chatId])
  @@index([userId, createdAt])
}

model TaskDraftRevision {
  id            String    @id @default(cuid())
  draftId       String
  revisionIndex Int
  schemaVersion String    @default("1.0")
  userNotes     String?   @db.Text
  understanding Json?
  intent        Json?
  schema        Json
  schemeDescription String? @db.Text
  assumptions   Json?
  ambiguities   Json?
  createdAt     DateTime  @default(now())
  draft         TaskDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, revisionIndex])
  @@index([draftId, createdAt])
}
