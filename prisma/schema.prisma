generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  createdAt    DateTime   @default(now())
  chats        Chat[]
  sessions     Session[]
  drafts       TaskDraft[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Chat {
  id              String     @id @default(cuid())
  userId          String
  title           String     @default("New chat")
  modelPreference String     @default("auto")
  isPinned        Boolean    @default(false)
  isPublic        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  drafts          TaskDraft[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum DraftStatus {
  DRAFT
  SCHEMA_GENERATED
  AWAITING_REVIEW
  NEEDS_REVISION
  SCHEMA_APPROVED
  SOLVING
  SOLVED
  CANCELED
  FAILED
}

model Message {
  id            String      @id @default(cuid())
  chatId        String
  draftId       String?
  role          MessageRole
  content       String      @db.Text
  generatedCode String?     @db.Text
  executionLogs String?     @db.Text
  graphData     Json?
  schemaData    Json?
  schemaVersion String?     @default("1.0")
  usedModels    Json?
  imageData     String?     @db.Text
  createdAt     DateTime    @default(now())
  chat          Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  draft         TaskDraft?  @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([chatId])
  @@index([draftId])
}

model TaskDraft {
  id               String              @id @default(cuid())
  chatId            String
  userId            String
  mode              String              @default("standard")
  status            DraftStatus         @default(DRAFT)
  schemaVersion     String              @default("1.0")
  originalPrompt    String              @db.Text
  originalImageData String?             @db.Text
  currentIntent     Json?
  approvedIntent    Json?
  currentSchema     Json?
  approvedSchema    Json?
  solverModel       Json?
  revisionCount     Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  chat              Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions         TaskDraftRevision[]
  messages          Message[]

  @@index([chatId])
  @@index([userId, createdAt])
}

model TaskDraftRevision {
  id            String    @id @default(cuid())
  draftId       String
  revisionIndex Int
  schemaVersion String    @default("1.0")
  userNotes     String?   @db.Text
  intent        Json?
  schema        Json
  assumptions   Json?
  ambiguities   Json?
  createdAt     DateTime  @default(now())
  draft         TaskDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, revisionIndex])
  @@index([draftId, createdAt])
}
