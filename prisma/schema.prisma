// PWA AI-Ассистент для точных наук — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  chats        Chat[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Chat {
  id              String    @id @default(cuid())
  userId          String
  title           String    @default("Новый чат")
  modelPreference String    @default("auto") // "auto" или конкретная модель
  isPinned        Boolean   @default(false)
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id            String      @id @default(cuid())
  chatId        String
  role          MessageRole
  content       String      @db.Text
  generatedCode String?     @db.Text
  executionLogs String?     @db.Text
  graphData     Json?       // Теперь массив объектов [{ title, points: [{x,y}, ...] }]
  usedModels    Json?       // Список моделей: ["gemini-3.1-pro-preview", ...]
  imageData     String?     @db.Text
  createdAt     DateTime    @default(now())
  chat          Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}
