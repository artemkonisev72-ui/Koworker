			</math>
			<rendering item-idref="9"/>
		</region>
		<region region-id="89" left="36" top="369" width="66" height="33" align-x="48.75" align-y="390" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
