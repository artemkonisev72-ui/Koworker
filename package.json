{
	"name": "coworker",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"prisma:generate": "prisma generate",
		"sync:pyodide": "node ./scripts/sync-pyodide-assets.mjs",
		"dev": "npm run sync:pyodide && npm run prisma:generate && vite dev",
		"dev:testdb": "npm run db:test:push && node --env-file=.env.test ./node_modules/vite/bin/vite.js dev",
		"build": "npm run sync:pyodide && vite build",
		"preview": "npm run sync:pyodide && vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"sandbox:service": "node --import tsx/esm src/lib/server/sandbox/service.ts",
		"db:test:push": "npm run prisma:generate && prisma db push --url postgresql://postgres@127.0.0.1:5433/coworker_test",
		"db:test:reset": "npm run prisma:generate && prisma db push --force-reset --accept-data-loss --url postgresql://postgres@127.0.0.1:5433/coworker_test",
		"test:db": "npm run db:test:push && npm run test",
		"build:worker": "esbuild src/lib/server/sandbox/pyodide-worker.ts --bundle=false --platform=node --format=esm --outfile=src/lib/server/sandbox/pyodide-worker.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@types/nodemailer": "^8.0.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@google/genai": "^1.46.0",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@types/dompurify": "^3.0.5",
		"@types/katex": "^0.16.8",
		"@types/pg": "^8.20.0",
		"dompurify": "^3.3.3",
		"dotenv": "^17.3.1",
		"jsxgraph": "^1.12.2",
		"katex": "^0.16.43",
		"mammoth": "^1.12.0",
		"marked": "^17.0.5",
		"nodemailer": "^8.0.5",
		"pdfjs-dist": "^5.7.284",
		"pg": "^8.20.0",
		"prisma": "^7.5.0",
		"pyodide": "^0.29.3"
	}
}
